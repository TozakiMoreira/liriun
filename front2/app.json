{
  "expo": {
    "name": "Jarvis",
    "slug": "jarvis",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "jarvis",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#08090a",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jarvisbytomore.jarvis"
    },
    "android": {
      "package": "com.jarvisbytomore.jarvis"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
