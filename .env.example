# Liriun — variáveis de ambiente (template)
# Copie este arquivo pra .env.local e preencha com os valores reais.
# .env.local NÃO vai pro git (está no .gitignore).

# ===== Supabase (PostgreSQL) =====
# Pegue em: Supabase Dashboard → Project Settings → Database → Connection string (Direct)
SUPABASE_DB_HOST=db.seu-projeto-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=sua-senha-do-banco

# Connection string pronta pro EF Core / Npgsql (.NET)
# Formato: Host=...;Port=...;Database=...;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true
DATABASE_CONNECTION_STRING=Host=db.seu-projeto-ref.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=sua-senha;SSL Mode=Require;Trust Server Certificate=true

# ===== Google Gemini API =====
# Pegue em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua-chave-gemini

# ===== JWT (autenticação do Liriun) =====
# Gere uma secret aleatória forte (ex: openssl rand -base64 64)
JWT_SECRET=troque-por-uma-secret-aleatoria-longa
JWT_ISSUER=liriun-api
JWT_AUDIENCE=liriun-app
JWT_EXPIRATION_MINUTES=1440
